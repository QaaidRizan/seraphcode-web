# --- Contact form: Gmail API (Google Cloud) ---
# 1) https://console.cloud.google.com → create/select a project
# 2) APIs & Services → Library → enable "Gmail API"
# 3) APIs & Services → OAuth consent screen → External (or Internal for Workspace) → add scope …/auth/gmail.send
# 4) APIs & Services → Credentials → Create Credentials → OAuth client ID
#    - Application type: Web application
#    - Authorized redirect URI: https://developers.google.com/oauthplayground
# 5) Open https://developers.google.com/oauthplayground
#    - Gear icon → check "Use your own OAuth credentials" → paste Client ID & Secret
#    - Left: find Gmail API v1 → https://www.googleapis.com/auth/gmail.send → Authorize APIs
#    - Exchange authorization code for tokens → copy Refresh token below

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=1//0g...

# Must be the Google account that completed the OAuth flow (the mailbox that sends mail)
GMAIL_SENDER_EMAIL=you@gmail.com

# Where submissions are delivered (comma-separated allowed). If unset, uses SITE.email from lib/constants.ts
# CONTACT_TO_EMAIL=you@gmail.com

# Optional. Defaults to "SeraphCode Website <GMAIL_SENDER_EMAIL>"
# GMAIL_FROM=SeraphCode <you@gmail.com>
